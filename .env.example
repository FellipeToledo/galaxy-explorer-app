# Proxy de tradução (server/index.mjs)
# Copie para .env e preencha. NUNCA versione o .env real.

# Chave da DeepL (https://www.deepl.com/pro-api). Free tier: 500k chars/mês.
DEEPL_API_KEY=

# Endpoint: free por padrão. Para conta Pro use https://api.deepl.com/v2/translate
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Porta do proxy (opcional)
# PORT=3001

# Modo de teste sem chave: 1 → traduções fictícias «texto» (só para dev)
# TRANSLATE_MOCK=1
