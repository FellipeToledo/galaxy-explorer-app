# Proxy de tradução (server/index.mjs)
# Copie para .env e preencha. NUNCA versione o .env real.

# Chave da DeepL (https://www.deepl.com/pro-api). Free tier: 500k chars/mês.
DEEPL_API_KEY=

# Endpoint: escolhido AUTOMATICAMENTE pelo formato da chave —
#   termina em ":fx" → conta Free → https://api-free.deepl.com/v2/translate
#   caso contrário   → conta Pro  → https://api.deepl.com/v2/translate
# Host errado para o tipo da chave = 403 (parece "chave inválida"). Só defina
# a variável abaixo se souber que precisa forçar algo diferente disso.
# DEEPL_API_URL=

# Porta do proxy (opcional)
# PORT=3001

# Modo de teste sem chave: 1 → traduções fictícias «texto» (só para dev)
# TRANSLATE_MOCK=1

# ── Cache durável (opcional) ────────────────────────────────────────────────
# Sem isto, o cache de tradução vive só em memória e some no cold start do
# serverless (cada instância nova volta a pagar DeepL pelos mesmos textos).
# Na Vercel, criar um KV/Upstash já injeta estas duas variáveis no projeto.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# Upstash direto (fora da Vercel) usa este par:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
